<launch>

  <!-- Perception -->
  <node pkg="me5413_world"
        type="box_counter_perception.py"
        name="box_counter_perception"
        output="screen">

    <param name="rate" value="10" />

    <param name="image_topic" value="/kinect/rgb/image_raw" />
    <param name="camera_info_topic" value="kinect/rgb/camera_info" />
    <param name="scan_topic" value="/front/scan" />
    <param name="odom_topic" value="/final_slam/odom" />

    <param name="counting_enabled_initial" value="true" />
    <param name="enable_counting_topic" value="/percep/enable_counting" />

    <param name="lidar_frame" value="front_laser" />
    <param name="map_frame" value="map" />

    <param name="use_gpu" value="true" />

    <param name="ocr_conf_thresh" value="0.90" />
    <param name="min_diag_len" value="45.0" />
    <param name="max_text_len" value="1" />

    <param name="required_stable_hits" value="3" />
    <param name="same_obs_time_window" value="1.0" />

    <param name="front_range_min" value="0.15" />
    <param name="front_range_max" value="8.0" />
    <param name="search_half_window" value="2" />
    <param name="range_offset" value="0.0" />

    <param name="dedup_radius" value="0.60" />

    <param name="use_floor_filter" value="false" />
    <param name="floor_x_min" value="7.0" />
    <param name="floor_x_max" value="17.0" />
    <param name="floor_y_min" value="-7.2" />
    <param name="floor_y_max" value="2.0" />
    <param name="floor_z_min" value="0.0" />
    <param name="floor_z_max" value="2.0" />

    <param name="use_center_roi" value="false" />
    <param name="center_roi_w_ratio" value="0.8" />
    <param name="center_roi_h_ratio" value="0.8" />

    <param name="debug_view" value="true" />
    <param name="debug_image_topic" value="/percep/debug_image" />

    <param name="output_yaml"
           value="$(find me5413_world)/records/box_counts.yaml" />
    <param name="records_topic" value="/percep/numbers" />
    <param name="target_pose_topic" value="/percep/pose" />

    <param name="enable_cone_trigger" value="true" />
    <param name="cone_trigger_topic" value="/cmd_unblock" />
    <param name="cone_trigger_distance" value="1.2" />
    <param name="cone_trigger_cooldown" value="2.0" />
  </node>
  
</launch>