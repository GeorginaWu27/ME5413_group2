<launch>

  <!-- Connect the robot to a keyboard teleop controller -->
  <node name="teleop_twist_keyboard" pkg="teleop_twist_keyboard" type="mbot_teleop.py" output="screen" respawn="true"/>

  <!-- Run the map server -->
  <arg name="map_file" default="$(find me5413_world)/maps/world_map.yaml"/>
  <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_file)" />
  
  <!-- Launch the AMCL Localizer -->
  <include file="$(find me5413_navigation)/launch/amcl.launch" />

  <!-- Launch Move Base -->
  <include file="$(find me5413_navigation)/launch/move_base.launch" />
  
  <!-- Launch slope mode controller -->
  <include file="$(find me5413_navigation)/launch/slope_mode_controller.launch" />

  <!-- Launch vision -->
  <!-- Perception: 一楼 box_counter（启动时自动调用） -->
  <include file="$(find me5413_world)/launch/box_counter_perception.launch"/>
  <!-- Perception Switcher：监听 cone trigger，锁定 counts，接管二楼进房逻辑 -->
  <node pkg="me5413_world"
        type="perception_switcher.py"
        name="perception_switcher"
        output="screen">
    <!-- trigger -->
    <param name="cone_trigger_topic"       value="/cmd_unblock" />
    <param name="box_counter_node_name"    value="/box_counter_perception" />
    <!-- counts & digit 来源 -->
    <param name="records_topic"            value="/percep/numbers" />
    <param name="current_seen_digit_topic" value="/percep/current_seen_digit" />
    <!-- 进房间发布目标 -->
    <param name="enter_room_topic"         value="/second_floor/enter_room" />
    <param name="enter_trigger_topic"      value="/second_floor/enter_room_trigger" />
  </node>

  <!-- Launch line -->
  <include file="$(find me5413_navigation)/launch/patrol_navigation.launch" />
  
  <!-- Launch Rviz with our settings -->
  <node type="rviz" name="rviz" pkg="rviz" args="-d $(find me5413_world)/rviz/navigation.rviz" output="log" respawn="true"/>

  <node ns="me5413_world" pkg="me5413_world" type="goal_publisher_node" name="goal_publisher_node" output="screen" />

</launch>
