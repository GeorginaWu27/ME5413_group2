include "map_builder.lua"
include "trajectory_builder.lua"

options = {
  map_builder = MAP_BUILDER,
  trajectory_builder = TRAJECTORY_BUILDER,

  map_frame = "map",
  tracking_frame = "imu_link",
  published_frame = "base_link",
  odom_frame = "odom",

  provide_odom_frame = true,
  publish_frame_projected_to_2d = true,

  use_pose_extrapolator = true,
  use_odometry = true,
  use_nav_sat = true,
  use_landmarks = false,
  publish_to_tf = true,

  num_laser_scans = 1,
  num_multi_echo_laser_scans = 0,
  num_subdivisions_per_laser_scan = 1,
  num_point_clouds = 0,

  lookup_transform_timeout_sec = 0.2,
  submap_publish_period_sec = 0.3,
  pose_publish_period_sec = 5e-3,
  trajectory_publish_period_sec = 30e-3,

  rangefinder_sampling_ratio = 1.0,
  odometry_sampling_ratio = 1.0,
  fixed_frame_pose_sampling_ratio = 1.0,
  imu_sampling_ratio = 1.0,
  landmarks_sampling_ratio = 1.0,
}

-- Enable the 2D trajectory builder for planar SLAM.
MAP_BUILDER.use_trajectory_builder_2d = true

-- Still use IMU data, but avoid relying too heavily on odometry.
TRAJECTORY_BUILDER_2D.use_imu_data = true

-- LiDAR measurement range:
-- use a more conservative range to reduce near-field noise and unstable long-range returns.
TRAJECTORY_BUILDER_2D.min_range = 0.20
TRAJECTORY_BUILDER_2D.max_range = 20.0
TRAJECTORY_BUILDER_2D.missing_data_ray_length = 3.0

-- Process each scan individually to preserve real-time performance.
TRAJECTORY_BUILDER_2D.num_accumulated_range_data = 1

-- Do not make the submap too large, so that data collected before and after the slope
-- is not forced into the same submap.
TRAJECTORY_BUILDER_2D.submaps.num_range_data = 300

-- Enable online correlative scan matching.
TRAJECTORY_BUILDER_2D.use_online_correlative_scan_matching = true

-- Slightly relax the search window compared with the current version.
-- This allows the scan matcher to recover if the odometry-based initial estimate drifts on the slope.
TRAJECTORY_BUILDER_2D.real_time_correlative_scan_matcher.linear_search_window = 0.15
TRAJECTORY_BUILDER_2D.real_time_correlative_scan_matcher.angular_search_window = math.rad(20.0)

-- Reduce the tendency to follow the odometry prediction too rigidly.
TRAJECTORY_BUILDER_2D.real_time_correlative_scan_matcher.translation_delta_cost_weight = 10.0
TRAJECTORY_BUILDER_2D.real_time_correlative_scan_matcher.rotation_delta_cost_weight = 0.5

-- Use relatively balanced weights for the Ceres scan matcher.
-- These two parameters affect the penalty on translation and rotation deviation during local matching.
TRAJECTORY_BUILDER_2D.ceres_scan_matcher.translation_weight = 5.0
TRAJECTORY_BUILDER_2D.ceres_scan_matcher.rotation_weight = 20.0

-- Use a more robust global optimization setting.
POSE_GRAPH.optimization_problem.huber_scale = 1e2

-- Do not optimize every 5 nodes as in the current version,
-- since that can propagate slope-induced errors too quickly.
POSE_GRAPH.optimize_every_n_nodes = 30

-- Matching scores may naturally be lower on slopes,
-- so the acceptance threshold should not be too strict.
POSE_GRAPH.constraint_builder.min_score = 0.55

-- Explicitly reduce the odometry constraint weight in the pose graph.
-- This prevents the global graph from being overly dominated by wheel odometry that may slip on slopes.
POSE_GRAPH.optimization_problem.odometry_translation_weight = 1e4
POSE_GRAPH.optimization_problem.odometry_rotation_weight = 1e4

return options